generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Order {
  id             String    @id
  itemName       String
  itemPrice      Int
  amountExpected Int
  amountPaid     Int?
  status         String    @default("pending") // pending, paid, mismatch, refunded
  qrUrl          String?
  expiryAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  payments       Payment[]
  refunds        Refund[]
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String
  amount    Int
  raw       Json
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
}

model Refund {
  id        String   @id @default(uuid())
  orderId   String
  amount    Int
  status    String   // pending, success, failed
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
}